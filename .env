# Polygon RPC
POLYGON_WSS=
POLYGON_HTTP=
WATCH_WALLET=

PROXY_URL=http://127.0.0.1:7890
UI_PORT=3001
UI_HOST=127.0.0.1
UI_SECRET=
POLYMARKET_COLLATERAL_TOKEN=

# Monitor stability
FETCH_TIMEOUT_MS=30000
DISCOVERY_ANALYZE_TIMEOUT_MS=15000
DISCOVERY_LEADERBOARD_TIMEOUT_MS=30000
DISCOVERY_CONCURRENCY=1
ENABLE_CHAIN_BALANCE_CHECK=false
BALANCE_QUERY_TIMEOUT_MS=12000
MARKET_CACHE_TTL_MS=1800000
ORDERBOOK_CACHE_TTL_MS=45000

# QQ Bot
QQ_APP_ID=
QQ_CLIENT_SECRET=
QQBOT_TARGET_TYPE=c2c
QQBOT_TARGET_ID=
QQ_SANDBOX=false
QQ_PUSH_ACTIVE_BUY_EXIT_ONLY=true
QQ_PUSH_HIGH_QUALITY_ONLY=true
SIGNAL_MIN_WALLET_SCORE=65
SIGNAL_MIN_NOTIONAL_USD=3
SIGNAL_MIN_DEPTH_USD=50

# Selected project exit monitoring
TRACKED_EXIT_ONLY=true
EXIT_ACTIVITY_WATCH_ENABLED=true
EXIT_ACTIVITY_POLL_MS=20000
EXIT_ACTIVITY_LOOKBACK_LIMIT=80
EXIT_ACTIVITY_MIN_USD=1
EXIT_ACTIVITY_MAX_SIGNALS_PER_WALLET_POLL=8
EXIT_POSITION_WATCH_ENABLED=true
EXIT_POSITION_POLL_MS=30000
EXIT_POSITION_MIN_SIZE_DELTA=0.01
EXIT_POSITION_MIN_SHARE_DELTA=0.1
EXIT_POSITION_MIN_SIZE_DELTA_PCT=0.001
EXIT_POSITION_REQUIRE_DISPLAY_SHARE_DROP=true
EXIT_POSITION_MIN_VALUE_DELTA_USD=1
EXIT_POSITION_TRACK_MIN_VALUE_USD=5
EXIT_POSITION_ALERT_ON_MISSING=false
EXIT_BATCH_ENABLED=true
EXIT_ALERT_COOLDOWN_MS=600000

# Polymarket CLOB trading connector - default safe mode
PM_PRIVATE_KEY=
PM_FUNDER_ADDRESS=
PM_SIGNATURE_TYPE=1

PM_API_KEY=
PM_API_SECRET=
PM_API_PASSPHRASE=


PM_CHAIN_ID=137
PM_CLOB_HOST=https://clob.polymarket.com
PM_API_KEY_NONCE=0
CLOB_PROXY_ENABLED=true
CLOB_FETCH_TIMEOUT_MS=30000

# ===== 秒级自动跟单 / 真实资金开关 =====
# 建议先用 sign 跑 1-2 小时：AUTO_TRADE_MODE=sign, AUTO_TRADE_DRY_RUN=true
# 确认无误后再打开 live。live 会使用真实资金。
TX_FLUSH_DELAY_MS=1200

SIGNAL_MAX_PRICE_DIFF=0.05
SIGNAL_FOLLOW_SAMPLE_USD=1

AUTO_TRADE_ENABLED=true
AUTO_TRADE_MODE=live
AUTO_TRADE_DRY_RUN=false
AUTO_TRADE_ALLOW_LIVE_AUTO=true
AUTO_TRADE_LIVE_TEST_ENABLED=true
AUTO_TRADE_REQUIRE_TRACKED_PROJECT=false
AUTO_TRADE_USD_PER_ORDER=1
AUTO_TRADE_MAX_ORDER_USD=5
AUTO_TRADE_MAX_PRICE_DIFF=0.05
AUTO_TRADE_MIN_DEPTH_USD=50
AUTO_TRADE_MIN_PRICE=0.02
AUTO_TRADE_MAX_PRICE=0.95
AUTO_TRADE_DAILY_MAX_USD=50
AUTO_TRADE_ORDER_TYPE=FAK
AUTO_TRADE_DUPLICATE_COOLDOWN_MS=60000
AUTO_TRADE_MIN_SECONDS_BETWEEN_WALLET_TRADES=3

# ===== 我的账户资金面板 / QQ 资金变化推送 =====
ACCOUNT_BALANCE_POLL_MS=10000
ACCOUNT_BALANCE_PUSH_ENABLED=true
ACCOUNT_BALANCE_PUSH_INTERVAL_MS=600000
ACCOUNT_BALANCE_PUSH_MIN_DELTA_USD=0

# Auto exit: treat any selected-project exit reminder as full close for your own position.
# Keep global live switches strict; live auto exit also needs AUTO_TRADE_ENABLED=true, AUTO_TRADE_DRY_RUN=false, AUTO_TRADE_ALLOW_LIVE_AUTO=true.
AUTO_EXIT_ENABLED=true
AUTO_EXIT_MODE=global
AUTO_EXIT_ON_ANY_EXIT=true
AUTO_EXIT_ORDER_TYPE=FAK
AUTO_EXIT_MAX_SLIPPAGE=0.05
AUTO_EXIT_MIN_BID=0.01
AUTO_EXIT_MIN_SHARES=0.01
AUTO_EXIT_DUPLICATE_COOLDOWN_MS=60000
AUTO_TRACK_PROJECT_AFTER_BUY=true

# ===== 安全控制 =====
# 紧急停止开关：设为 true 立即停止所有自动交易（可从 UI 控制）
KILL_SWITCH=false
# 余额告警阈值：余额低于此值时发出警告
BALANCE_ALERT_USD=0

AUTO_TRADE_MAX_ACTIVE_PROJECTS=6
AUTO_TRADE_MAX_TOTAL_PROJECTS=12
AUTO_TRADE_MAX_SETTLEMENT_WAIT_PROJECTS=6
AUTO_TRADE_MAX_SETTLEMENT_WAIT_USD=50
AUTO_TRADE_MIN_FREE_CASH_USD=0
AUTO_TRADE_POSITION_DUST_USD=0.10
AUTO_TRADE_BLOCK_IF_SETTLEMENT_OVER_LIMIT=true

# ===== 自动跟单：已持有同档位就不再加仓 =====
# true = 如果你的账户已经持有同一个 tokenId / 同一个档位，就跳过新的自动买入。
AUTO_TRADE_SKIP_IF_HOLDING_SAME_TOKEN=true
# 持仓 shares 大于这个值就视为“已经持有”。默认非常小，避免 0.1¢ 残留仓继续被加仓。
AUTO_TRADE_SAME_TOKEN_MIN_SHARES=0.000001

AUTO_TAKE_PROFIT_ENABLED=true
AUTO_TAKE_PROFIT_PCT=350
AUTO_TAKE_PROFIT_MODE=global
AUTO_TAKE_PROFIT_ORDER_TYPE=FAK
AUTO_TAKE_PROFIT_MAX_SLIPPAGE=0.05
AUTO_TAKE_PROFIT_MIN_BID=0.01
AUTO_TAKE_PROFIT_MIN_SHARES=0.01
AUTO_TAKE_PROFIT_MIN_VALUE_USD=0.50
AUTO_TAKE_PROFIT_DUPLICATE_COOLDOWN_MS=600000
AUTO_TAKE_PROFIT_MAX_PER_POLL=3

# ===== 追踪高水位止盈 / 止损 / 价格地板 =====
# 追踪止盈：盈利超过 ACTIVATE_PCT 后开始追踪最高价；从高点回撤 DRAWDOWN_PCT 自动卖出
AUTO_TRAILING_STOP_ENABLED=true
AUTO_TRAILING_STOP_ACTIVATE_PCT=30
AUTO_TRAILING_STOP_DRAWDOWN_PCT=30
AUTO_TRAILING_STOP_MIN_VALUE_USD=0.50
AUTO_TRAILING_STOP_MAX_PER_POLL=3

# 止损：当 PnL 跌破 -STOP_LOSS_PCT 时自动卖出（防止本金大幅亏损）
AUTO_STOP_LOSS_ENABLED=true
AUTO_STOP_LOSS_PCT=50
AUTO_STOP_LOSS_MIN_VALUE_USD=0.30
AUTO_STOP_LOSS_MAX_PER_POLL=3

# 价格地板：当 token 价格跌破此绝对值时自动卖出（市场概率崩塌信号）
AUTO_PRICE_FLOOR_ENABLED=true
AUTO_PRICE_FLOOR_PRICE=0.05
AUTO_PRICE_FLOOR_MIN_VALUE_USD=0.30
AUTO_PRICE_FLOOR_MAX_PER_POLL=3

ACCOUNT_BALANCE_PUSH_COMPACT=true
ACCOUNT_BALANCE_PUSH_MAX_POSITIONS=8
ACCOUNT_BALANCE_PUSH_INCLUDE_DUST=false
ACCOUNT_QQ_POSITION_MIN_VALUE_USD=0.01

QQ_TRADE_COMMANDS_ENABLED=true
QQ_SELL_COMMAND_MODE=live
QQ_SELL_COMMAND_ORDER_TYPE=FAK
QQ_SELL_COMMAND_MAX_SLIPPAGE=0.05
QQ_SELL_COMMAND_MIN_BID=0.01
